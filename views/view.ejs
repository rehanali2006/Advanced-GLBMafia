<% layout('/layouts/boilerplate') %>

<link rel="stylesheet" href="/css/view.css">

<div class="view-container">

    <div class="resource-card">

        <!-- Full PDF Viewer via Google Docs Viewer -->
        <div class="pdf-viewer-section">

            <iframe
                src="https://docs.google.com/viewer?url=<%= encodeURIComponent(resource.file) %>&embedded=true"
                class="pdf-full-frame"
                frameborder="0"
                allowfullscreen
                title="PDF Viewer"
            ></iframe>

        </div>

        <div class="details-section">

            <h1>
                <%= resource.title || "Study Resource" %>
            </h1>

            <div class="resource-info">

                <span class="badge-item">
                    <i class="bi bi-book"></i>
                    <%= resource.subject %>
                </span>

                <span class="badge-item">
                    <i class="bi bi-layers"></i>
                    Unit <%= resource.unit %>
                </span>

                <span class="badge-item">
                    <i class="bi bi-file-earmark-text"></i>
                    <%= resource.type %>
                </span>

                <span class="badge-item">
                    <i class="bi bi-eye"></i>
                    <%= resource.views %> views
                </span>

            </div>

            <% if(resource.description) { %>
                <p class="description">
                    <%= resource.description %>
                </p>
            <% } %>

            <div class="action-buttons">

                <!-- Open PDF directly in new tab -->
                <a
                    href="https://docs.google.com/viewer?url=<%= encodeURIComponent(resource.file) %>"
                    target="_blank"
                    class="btn-open"
                >
                    <i class="bi bi-box-arrow-up-right"></i>
                    Open in Full Screen
                </a>

                <!-- Download the original PDF from Cloudinary -->
                <a
                    href="<%= resource.file %>"
                    target="_blank"
                    download
                    class="btn-open"
                    style="background: #27ae60;"
                >
                    <i class="bi bi-download"></i>
                    Download PDF
                </a>

                <% if(currentUser && resource.owner && resource.owner.toString() === currentUser._id.toString()) { %>
                <form
                    action="/resource/delete/<%= resource._id %>?_method=DELETE"
                    method="POST"
                    onsubmit="return confirm('Are you sure you want to delete this resource? This cannot be undone.')"
                >
                    <button class="btn-delete">
                        <i class="bi bi-trash-fill"></i>
                        Delete Resource
                    </button>
                </form>
                <% } %>

            </div>

        </div>

    </div>

</div>

<style>
.pdf-viewer-section {
    width: 100%;
    height: 75vh;
    min-height: 500px;
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 1.5rem;
    background: #f5f5f5;
    border: 1px solid #ddd;
}

.pdf-full-frame {
    width: 100%;
    height: 100%;
    border: none;
}
</style>
