<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error - GLB Mafia</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/boilerplate.css">
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark sticky-top glb-navbar">
        <div class="container">
            <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/">
                <span class="brand-icon">📚</span>
                <span>GLB Mafia</span>
            </a>
        </div>
    </nav>

    <div class="container d-flex flex-column align-items-center justify-content-center" style="min-height: 80vh;">
        <div class="text-center">
            <h1 class="display-1 fw-bold" style="color: #667eea;"><%= status %></h1>
            <h3 class="mb-3">Oops! Something went wrong</h3>
            <p class="text-muted fs-5"><%= message %></p>
            <a href="/" class="btn btn-dark mt-3 px-4">
                <i class="bi bi-house-door me-2"></i>Back to Home
            </a>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
